---
layout: none
---
<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="{{ '/assets/feed.xsl' | absolute_url }}"?>
<feed xmlns="http://www.w3.org/2005/Atom">

  <title>{{ site.title | xml_escape }}</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <link href="{{ '/feed.xml' | absolute_url }}" rel="self" type="application/atom+xml"/>
  <link href="{{ '/' | absolute_url }}" rel="alternate" type="text/html"/>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ '/' | absolute_url }}</id>

  {% if site.author.name %}
  <author>
    <name>{{ site.author.name | xml_escape }}</name>
    <!-- email intentionally omitted — prevents spam harvesting from public RSS feed -->
  </author>
  {% endif %}

  {% assign feed_posts = site.posts | limit: 20 %}
  {% for post in feed_posts %}
  <entry>
    <title>{{ post.title | xml_escape }}</title>
    <link href="{{ post.url | absolute_url }}" rel="alternate" type="text/html"
          title="{{ post.title | xml_escape }}"/>
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.date | date_to_xmlschema }}</updated>
    <id>{{ post.url | absolute_url }}</id>
    {% if post.excerpt %}
    <summary>{{ post.excerpt | strip_html | xml_escape | truncate: 200 }}</summary>
    {% endif %}
    <content type="html" xml:base="{{ post.url | absolute_url }}">
      {{ post.content | xml_escape }}
    </content>
    {% if post.author %}
    <author>
      <name>{{ post.author | xml_escape }}</name>
    </author>
    {% endif %}
    {% assign post_category = post.categories | first | default: post.category %}
    {% if post_category %}
    <category term="{{ post_category | xml_escape }}"/>
    {% endif %}
  </entry>
  {% endfor %}

</feed>
